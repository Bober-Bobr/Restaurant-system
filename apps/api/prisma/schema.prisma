generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum EventStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum EventType {
  RESERVATION
  BANQUET
  WEDDING
  PRIVATE_PARTY
  CORPORATE
}

enum MenuCategory {
  COLD_APPETIZERS
  HOT_APPETIZERS
  SALADS
  FIRST_COURSE
  SECOND_COURSE
  DRINKS
  SWEETS
  FRUITS
}

enum Region {
  US
  CA
  GB
  DE
  FR
  IT
  ES
  RU
  CN
  JP
  KR
  AU
  UZ
  EU
}

model Event {
  id              String            @id @default(cuid())
  eventNumber     Int               @unique @default(0)
  customerName    String
  customerPhone   String?
  eventDate       DateTime
  guestCount      Int
  status          EventStatus       @default(DRAFT)
  eventType       EventType         @default(RESERVATION)
  region          Region?
  hallId          String?
  tableCategoryId String?
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  selections      EventMenuSelection[]
  hall            Hall?             @relation(fields: [hallId], references: [id], onDelete: SetNull)
  tableCategory   TableCategory?    @relation(fields: [tableCategoryId], references: [id], onDelete: SetNull)

  @@index([hallId])
  @@index([tableCategoryId])
}

model AdminUser {
  id               String   @id @default(cuid())
  username         String   @unique
  passwordHash     String
  refreshTokenHash String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TableCategory {
  id                 String                    @id @default(cuid())
  name               String                    @unique
  includedCategories String                    @default("")
  ratePerPerson      Int                       @default(0)
  description        String?
  photoUrl           String?
  isActive           Boolean                   @default(true)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  events             Event[]
  packageItems       TableCategoryMenuItem[]
}

model TableCategoryMenuItem {
  id              String        @id @default(cuid())
  tableCategoryId String
  menuItemId      String
  tableCategory   TableCategory @relation(fields: [tableCategoryId], references: [id], onDelete: Cascade)
  menuItem        MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([tableCategoryId, menuItemId])
  @@index([tableCategoryId])
}

model Hall {
  id          String   @id @default(cuid())
  name        String   @unique
  capacity    Int
  description String?
  photoUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  events      Event[]
}

model MenuItem {
  id               String                    @id @default(cuid())
  name             String
  description      String?
  category         MenuCategory
  priceCents       Int
  photoUrl         String?
  isActive         Boolean                   @default(true)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  selections       EventMenuSelection[]
  packageCategories TableCategoryMenuItem[]

  @@index([category, isActive])
}

model EventMenuSelection {
  id             String   @id @default(cuid())
  eventId        String
  menuItemId     String
  quantity       Int
  unitPriceCents Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([eventId, menuItemId])
  @@index([eventId])
}
