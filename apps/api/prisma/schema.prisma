generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum EventStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

enum EventType {
  RESERVATION
  BANQUET
  WEDDING
  BIRTHDAY
  PRIVATE_PARTY
  CORPORATE
}

enum MenuCategory {
  COLD_APPETIZERS
  HOT_APPETIZERS
  SALADS
  FIRST_COURSE
  SECOND_COURSE
  DRINKS
  SWEETS
  FRUITS
}

enum Region {
  US
  CA
  GB
  DE
  FR
  IT
  ES
  RU
  CN
  JP
  KR
  AU
  UZ
  EU
}

model Event {
  id              String            @id @default(cuid())
  eventNumber     Int               @unique @default(0)
  customerName    String
  customerPhone   String?
  eventDate       DateTime
  guestCount      Int
  status          EventStatus       @default(DRAFT)
  eventType            EventType         @default(RESERVATION)
  region               Region?
  hallId               String?
  tableCategoryId      String?
  restaurantId         String?
  notes                String?
  birthdayPersonName   String?
  brideName            String?
  groomName            String?
  honoreePersonName    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  selections      EventMenuSelection[]
  hall            Hall?             @relation(fields: [hallId], references: [id], onDelete: SetNull)
  tableCategory   TableCategory?    @relation(fields: [tableCategoryId], references: [id], onDelete: SetNull)
  restaurant      Restaurant?       @relation(fields: [restaurantId], references: [id], onDelete: SetNull)

  @@index([hallId])
  @@index([tableCategoryId])
  @@index([restaurantId])
}

enum AdminRole {
  OWNER
  ADMIN
  EMPLOYEE
}

model AdminUser {
  id               String       @id @default(cuid())
  username         String       @unique
  passwordHash     String
  refreshTokenHash String?
  role             AdminRole    @default(OWNER)
  restaurantId     String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  ownedRestaurants Restaurant[] @relation("OwnedRestaurants")
  restaurant       Restaurant?  @relation("StaffRestaurant", fields: [restaurantId], references: [id], onDelete: SetNull)

  @@index([restaurantId])
}

model Restaurant {
  id              String          @id @default(cuid())
  name            String
  address         String?
  logoUrl         String?
  ownerId         String
  owner           AdminUser       @relation("OwnedRestaurants", fields: [ownerId], references: [id], onDelete: Cascade)
  staff           AdminUser[]     @relation("StaffRestaurant")
  events          Event[]
  menuItems       MenuItem[]
  tableCategories TableCategory[]
  halls           Hall[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([ownerId])
}

model TableCategory {
  id                 String                    @id @default(cuid())
  name               String
  includedCategories String                    @default("")
  ratePerPerson      Int                       @default(0)
  description        String?
  photoUrl           String?
  photos             Json                      @default("[]")
  isActive           Boolean                   @default(true)
  restaurantId       String?
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  events             Event[]
  packageItems       TableCategoryMenuItem[]
  restaurant         Restaurant?               @relation(fields: [restaurantId], references: [id], onDelete: SetNull)

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

model TableCategoryMenuItem {
  id              String        @id @default(cuid())
  tableCategoryId String
  menuItemId      String
  tableCategory   TableCategory @relation(fields: [tableCategoryId], references: [id], onDelete: Cascade)
  menuItem        MenuItem      @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([tableCategoryId, menuItemId])
  @@index([tableCategoryId])
}

model Hall {
  id           String      @id @default(cuid())
  name         String
  capacity     Int
  description  String?
  photoUrl     String?
  isActive     Boolean     @default(true)
  restaurantId String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  events       Event[]
  restaurant   Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: SetNull)

  @@unique([restaurantId, name])
  @@index([restaurantId])
}

model MenuItem {
  id               String                    @id @default(cuid())
  name             String
  description      String?
  category         MenuCategory
  priceCents       Int
  photoUrl         String?
  isActive         Boolean                   @default(true)
  restaurantId     String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  selections       EventMenuSelection[]
  packageCategories TableCategoryMenuItem[]
  restaurant       Restaurant?              @relation(fields: [restaurantId], references: [id], onDelete: SetNull)

  @@index([category, isActive])
  @@index([restaurantId])
}

model EventMenuSelection {
  id             String   @id @default(cuid())
  eventId        String
  menuItemId     String
  quantity       Int
  unitPriceCents Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([eventId, menuItemId])
  @@index([eventId])
}
